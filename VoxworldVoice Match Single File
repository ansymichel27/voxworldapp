  <script>
    const COUNTRY_COORDS = {
      "Haiti": { x: 260, y: 196 },
      "USA": { x: 210, y: 160 },
      "France": { x: 495, y: 150 },
      "Nigeria": { x: 545, y: 282 },
      "Canada": { x: 205, y: 118 },
      "Brazil": { x: 305, y: 318 },
      "UK": { x: 475, y: 142 },
      "Spain": { x: 480, y: 165 },
      "Germany": { x: 515, y: 150 },
      "Jamaica": { x: 245, y: 194 },
      "Dominican Republic": { x: 270, y: 194 },
      "Mexico": { x: 180, y: 185 },
      "South Africa": { x: 565, y: 382 },
      "Japan": { x: 845, y: 192 },
      "Australia": { x: 830, y: 360 }
    };

    function seededHash(str) {
      let hash = 0;
      for (let i = 0; i < str.length; i++) {
        hash = ((hash << 5) - hash) + str.charCodeAt(i);
        hash |= 0;
      }
      return Math.abs(hash);
    }
    function randomFromSeed(seed, min, max) {
      const x = Math.sin(seed) * 10000;
      const frac = x - Math.floor(x);
      return min + frac * (max - min);
    }
    function generateVocalDNA(name, country, style, bio) {
      const seed = seededHash(`${name}|${country}|${style}|${bio}`);
      const auraNames = ["Celestial Blue", "Solar Gold", "Neon Rose", "Royal Violet", "Ocean Pulse", "Crimson Echo", "Aurora Flame", "Midnight Wave"];
      const energyNames = ["Magnetic", "Elevated", "Balanced", "Expansive", "Radiant", "Dynamic", "Intense", "Velvet Pulse"];
      const matchNames = ["Creative Pulse", "Global Harmony", "Cinematic Aura", "World Fusion", "Voice Prestige", "Future Rhythm"];
      const emotionNames = ["Warm / Expansive", "Bold / Electric", "Velvet / Soulful", "Sacred / Rising", "Fresh / Magnetic", "Deep / Emotional"];
      const patternNames = ["Radiant Spiral", "Orbital Bloom", "Quantum Halo", "Echo Ring Matrix", "Solar Constellation", "Pulse Flower"];
      return {
        dnaId: `VX-${String((seed % 9000) + 1000)}-${String(((seed * 7) % 9000) + 1000)}`,
        primaryAura: auraNames[seed % auraNames.length],
        voiceEnergy: energyNames[(seed + 1) % energyNames.length],
        globalMatch: matchNames[(seed + 2) % matchNames.length],
        auraSignature: auraNames[(seed + 3) % auraNames.length],
        emotionalCore: emotionNames[(seed + 4) % emotionNames.length],
        voicePattern: patternNames[(seed + 5) % patternNames.length],
        power: Math.floor(randomFromSeed(seed + 11, 52, 97)),
        warmth: Math.floor(randomFromSeed(seed + 22, 45, 98)),
        clarity: Math.floor(randomFromSeed(seed + 33, 50, 97)),
        rhythm: Math.floor(randomFromSeed(seed + 44, 48, 99)),
        emotion: Math.floor(randomFromSeed(seed + 55, 54, 99)),
        hueA: Math.floor(randomFromSeed(seed + 66, 180, 340)),
        hueB: Math.floor(randomFromSeed(seed + 77, 190, 320)),
        hueC: Math.floor(randomFromSeed(seed + 88, 20, 80))
      };
    }

    const defaultArtists = [
      {
        id: crypto.randomUUID(), name: "Ansy Michel", country: "Haiti / USA", style: "Kompa",
        bio: "A visionary global artist identity blending Haitian cultural power, innovation, and a future-facing voice universe.",
        image: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1200&auto=format&fit=crop",
        audio: "", likes: 240, followers: 5400, collabs: 89, rank: "Top Rising"
      },
      {
        id: crypto.randomUUID(), name: "Lina Soul", country: "France", style: "Soul",
        bio: "Elegant vocal color, emotional depth, and premium performance energy built for global collaborations.",
        image: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=1200&auto=format&fit=crop",
        audio: "", likes: 198, followers: 3100, collabs: 52, rank: "Featured"
      },
      {
        id: crypto.randomUUID(), name: "Maya Beat", country: "Nigeria", style: "Afrobeat",
        bio: "Bright sonic identity, irresistible hooks, and global appeal for creator growth and collaboration.",
        image: "https://images.unsplash.com/photo-1488426862026-3ee34a7d66df?q=80&w=1200&auto=format&fit=crop",
        audio: "", likes: 412, followers: 9100, collabs: 140, rank: "Global Hot"
      }
    ].map(a => ({ ...a, dna: generateVocalDNA(a.name, a.country, a.style, a.bio) }));

    let artists = loadArtists();
    let spotlightArtist = artists[0] || null;
    let currentDNAArtist = null;
    let selectedMatchArtist = artists[0] || null;

    function loadArtists() {
      const saved = localStorage.getItem("voxworld_artists_dna_map_match");
      if (saved) return JSON.parse(saved);
      localStorage.setItem("voxworld_artists_dna_map_match", JSON.stringify(defaultArtists));
      return [...defaultArtists];
    }
    function saveArtists() {
      localStorage.setItem("voxworld_artists_dna_map_match", JSON.stringify(artists));
    }
    function scrollToSignup() { document.getElementById("signupBox").scrollIntoView({ behavior: "smooth" }); }
    function scrollToGallery() { document.getElementById("galleryBox").scrollIntoView({ behavior: "smooth" }); }
    function scrollToMap() { document.getElementById("worldMapSection").scrollIntoView({ behavior: "smooth" }); }
    function formatFollowers(num) { if (num >= 1000000) return (num / 1000000).toFixed(1) + "M"; if (num >= 1000) return (num / 1000).toFixed(1) + "K"; return String(num); }
    function escapeHtml(text) { const div = document.createElement("div"); div.textContent = text; return div.innerHTML; }

    function createArtistCard(artist) {
      const audioBlock = artist.audio
        ? `<audio controls><source src="${artist.audio}"></audio>`
        : `<div style="margin-bottom:15px;padding:12px;border-radius:14px;background:rgba(255,255,255,.04);color:#cbd5e1;font-size:13px;">Voice preview will appear here after upload.</div>`;
      return `
        <div class="artist-card" data-id="${artist.id}" data-name="${escapeHtml(artist.name)}" data-style="${escapeHtml(artist.style)}" data-country="${escapeHtml(artist.country)}" data-dna="${escapeHtml(artist.dna.dnaId)}">
          <div class="artist-media">
            <img src="${artist.image}" alt="${escapeHtml(artist.name)}">
            <span class="artist-chip">${escapeHtml(artist.style)} Voice</span>
            <span class="dna-chip">${escapeHtml(artist.dna.dnaId)}</span>
          </div>
          <div class="artist-content">
            <div class="artist-top">
              <div>
                <h3 class="artist-name">${escapeHtml(artist.name)}</h3>
                <div class="artist-meta">${escapeHtml(artist.country)} · ${escapeHtml(artist.style)}</div>
              </div>
              <span class="rank-badge">${escapeHtml(artist.rank || "Rising")}</span>
            </div>
            <p class="artist-bio">${escapeHtml(artist.bio)}</p>
            <div class="dna-row">
              <span class="dna-pill">${escapeHtml(artist.dna.primaryAura)}</span>
              <span class="dna-pill">${escapeHtml(artist.dna.voiceEnergy)}</span>
              <span class="dna-pill">${escapeHtml(artist.dna.voicePattern)}</span>
            </div>
            <div class="artist-stats">
              <div class="mini-stat"><strong class="likes-value">${artist.likes || 0}</strong><span>Likes</span></div>
              <div class="mini-stat"><strong>${formatFollowers(artist.followers || 0)}</strong><span>Followers</span></div>
              <div class="mini-stat"><strong>${artist.collabs || 0}</strong><span>Collabs</span></div>
            </div>
            ${audioBlock}
            <div class="artist-actions">
              <button class="like-btn" onclick="likeArtist('${artist.id}', this)">Like</button>
              <button class="follow-btn" onclick="setMatchArtist('${artist.id}')">Match</button>
              <button class="collab-btn" onclick="setSpotlight('${artist.id}')">Spotlight</button>
              <button class="dna-btn" onclick="openDNA('${artist.id}')">Vocal DNA</button>
            </div>
          </div>
        </div>`;
    }

    function renderArtists(list = artists) {
      const grid = document.getElementById("artistGrid");
      const empty = document.getElementById("emptyState");
      grid.innerHTML = list.map(createArtistCard).join("");
      empty.style.display = list.length ? "none" : "block";
      updateStats();
      updateSpotlight();
      renderMap();
      if (!selectedMatchArtist && artists.length) selectedMatchArtist = artists[0];
      renderVoiceMatches(selectedMatchArtist);
    }

    function updateStats() {
      const countries = new Set(artists.flatMap(a => a.country.split("/").map(x => x.trim()))).size;
      document.getElementById("countriesStat").textContent = countries + "+";
      document.getElementById("artistsStat").textContent = artists.length;
      document.getElementById("matchesStat").textContent = Math.max(artists.length - 1, 0) * 3;
    }

    function updateSpotlight() {
      if (!spotlightArtist && artists.length) spotlightArtist = artists[0];
      if (!spotlightArtist) return;
      document.getElementById("spotlightImage").src = spotlightArtist.image;
      document.getElementById("spotlightName").textContent = spotlightArtist.name;
      document.getElementById("spotlightDesc").textContent = `${spotlightArtist.style} · ${spotlightArtist.country} · ${spotlightArtist.bio}`;
      document.getElementById("spotlightDNA").textContent = spotlightArtist.dna.dnaId;
      document.getElementById("spotlightAura").textContent = spotlightArtist.dna.primaryAura;
      document.getElementById("spotlightEnergy").textContent = spotlightArtist.dna.voiceEnergy;
    }
    function setSpotlight(id) {
      const artist = artists.find(a => a.id === id);
      if (!artist) return;
      spotlightArtist = artist;
      updateSpotlight();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
    function openSpotlightDNA() { if (spotlightArtist) openDNA(spotlightArtist.id); }
    function openSpotlightMatch() { if (spotlightArtist) { setMatchArtist(spotlightArtist.id); scrollToMap(); } }

    function filterArtists() {
      const searchValue = document.getElementById("searchInput").value.toLowerCase();
      const styleValue = document.getElementById("styleFilter").value;
      const countryValue = document.getElementById("countryFilter").value;
      const filtered = artists.filter(artist => {
        const allText = `${artist.name} ${artist.style} ${artist.country} ${artist.bio} ${artist.dna.dnaId} ${artist.dna.primaryAura} ${artist.dna.voiceEnergy}`.toLowerCase();
        const matchesSearch = allText.includes(searchValue);
        const matchesStyle = styleValue === "all" || artist.style === styleValue;
        const matchesCountry = countryValue === "all" || artist.country.toLowerCase().includes(countryValue.toLowerCase());
        return matchesSearch && matchesStyle && matchesCountry;
      });
      renderArtists(filtered);
    }

    function likeArtist(id, button) {
      const artist = artists.find(a => a.id === id);
      if (!artist || button.classList.contains("liked")) return;
      artist.likes += 1;
      saveArtists();
      const likeValue = button.closest(".artist-card").querySelector(".likes-value");
      likeValue.textContent = artist.likes;
      button.textContent = "Liked";
      button.classList.add("liked");
      button.style.opacity = "0.82";
    }

    async function fileToBase64(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result);
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }

    document.getElementById("artistForm").addEventListener("submit", async function(e) {
      e.preventDefault();
      const name = document.getElementById("artistName").value.trim();
      const country = document.getElementById("artistCountry").value.trim();
      const style = document.getElementById("artistStyle").value;
      const bio = document.getElementById("artistBio").value.trim();
      const imageFile = document.getElementById("artistImage").files[0];
      const audioFile = document.getElementById("artistAudio").files[0];
      if (!name || !country || !style || !bio || !imageFile) {
        alert("Please complete all required fields.");
        return;
      }
      const imageBase64 = await fileToBase64(imageFile);
      const audioBase64 = audioFile ? await fileToBase64(audioFile) : "";
      const dna = generateVocalDNA(name, country, style, bio);
      const newArtist = {
        id: crypto.randomUUID(), name, country, style, bio, image: imageBase64, audio: audioBase64,
        likes: Math.floor(Math.random() * 60) + 10,
        followers: Math.floor(Math.random() * 900) + 100,
        collabs: Math.floor(Math.random() * 15) + 1,
        rank: "New Entry", dna
      };
      artists.unshift(newArtist);
      spotlightArtist = newArtist;
      selectedMatchArtist = newArtist;
      saveArtists();
      renderArtists();
      this.reset();
      document.getElementById("galleryBox").scrollIntoView({ behavior: "smooth" });
    });

    function normalizeCountry(country) {
      const first = country.split("/")[0].trim();
      if (COUNTRY_COORDS[first]) return first;
      const found = Object.keys(COUNTRY_COORDS).find(k => country.toLowerCase().includes(k.toLowerCase()));
      return found || null;
    }

    function renderMap() {
      const mapDots = document.getElementById("mapDots");
      const mapLegend = document.getElementById("mapLegend");
      const countryCards = document.getElementById("countryCards");
      const grouped = {};
      artists.forEach(artist => {
        const normalized = normalizeCountry(artist.country);
        if (!normalized) return;
        if (!grouped[normalized]) grouped[normalized] = [];
        grouped[normalized].push(artist);
      });
      mapDots.innerHTML = "";
      mapLegend.innerHTML = "";
      countryCards.innerHTML = "";
      Object.entries(grouped).forEach(([country, list]) => {
        const coord = COUNTRY_COORDS[country];
        if (!coord) return;
        const r = 8 + Math.min(list.length * 2, 12);
        const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
        circle.setAttribute("cx", coord.x);
        circle.setAttribute("cy", coord.y);
        circle.setAttribute("r", r);
        circle.setAttribute("fill", "rgba(56,189,248,.85)");
        circle.setAttribute("stroke", "rgba(255,255,255,.85)");
        circle.setAttribute("stroke-width", "2");
        circle.setAttribute("class", "country-dot");
        circle.addEventListener("click", () => selectCountry(country));
        mapDots.appendChild(circle);

        const glow = document.createElementNS("http://www.w3.org/2000/svg", "circle");
        glow.setAttribute("cx", coord.x);
        glow.setAttribute("cy", coord.y);
        glow.setAttribute("r", r + 10);
        glow.setAttribute("fill", "rgba(56,189,248,.12)");
        mapDots.appendChild(glow);

        const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
        text.setAttribute("x", coord.x + 12);
        text.setAttribute("y", coord.y - 12);
        text.setAttribute("fill", "#dbeafe");
        text.setAttribute("font-size", "12");
        text.textContent = country;
        mapDots.appendChild(text);

        mapLegend.innerHTML += `<span class="legend-pill">${country} • ${list.length} artist${list.length > 1 ? 's' : ''}</span>`;
        countryCards.innerHTML += `
          <div class="country-card">
            <h4>${country}</h4>
            <p>${list.map(a => a.name).join(", ")}</p>
            <strong>${list.length}</strong>
          </div>`;
      });
    }

    function selectCountry(country) {
      const countryArtists = artists.filter(a => normalizeCountry(a.country) === country);
      if (countryArtists.length) {
        setSpotlight(countryArtists[0].id);
        setMatchArtist(countryArtists[0].id);
      }
    }

    function similarityScore(a, b) {
      let score = 45;
      if (a.style === b.style) score += 22;
      if (normalizeCountry(a.country) === normalizeCountry(b.country)) score += 12;
      const dnaA = a.dna, dnaB = b.dna;
      const closeness = 100 - (
        Math.abs(dnaA.power - dnaB.power) +
        Math.abs(dnaA.warmth - dnaB.warmth) +
        Math.abs(dnaA.clarity - dnaB.clarity) +
        Math.abs(dnaA.rhythm - dnaB.rhythm) +
        Math.abs(dnaA.emotion - dnaB.emotion)
      ) / 5;
      score += Math.round(closeness * 0.28);
      return Math.min(score, 99);
    }

    function matchReasons(a, b) {
      const reasons = [];
      if (a.style === b.style) reasons.push(`Shared ${a.style} energy`);
      else reasons.push(`${a.style} x ${b.style} fusion`);
      if (normalizeCountry(a.country) === normalizeCountry(b.country)) reasons.push("Regional connection");
      else reasons.push("Cross-border discovery");
      if (Math.abs(a.dna.rhythm - b.dna.rhythm) < 12) reasons.push("Rhythm alignment");
      if (Math.abs(a.dna.emotion - b.dna.emotion) < 12) reasons.push("Emotional closeness");
      if (reasons.length < 3) reasons.push("Strong Vocal DNA contrast");
      return reasons.slice(0, 3);
    }

    function renderVoiceMatches(baseArtist) {
      const matchGrid = document.getElementById("matchGrid");
      if (!baseArtist) {
        matchGrid.innerHTML = `<div class="empty-state" style="display:block">Select an artist to see matches.</div>`;
        document.getElementById("matchForArtist").textContent = "Select an artist";
        document.getElementById("matchDNARef").textContent = "DNA Reference";
        return;
      }
      document.getElementById("matchForArtist").textContent = `Matching for ${baseArtist.name}`;
      document.getElementById("matchDNARef").textContent = baseArtist.dna.dnaId;
      const matches = artists
        .filter(a => a.id !== baseArtist.id)
        .map(other => ({ artist: other, score: similarityScore(baseArtist, other), reasons: matchReasons(baseArtist, other) }))
        .sort((x, y) => y.score - x.score)
        .slice(0, 3);
      if (!matches.length) {
        matchGrid.innerHTML = `<div class="empty-state" style="display:block">Add more artists to generate Voice Match proposals.</div>`;
        return;
      }
      matchGrid.innerHTML = matches.map(match => `
        <div class="match-card">
          <span class="match-score">${match.score}% match</span>
          <h4>${escapeHtml(match.artist.name)}</h4>
          <p>${escapeHtml(match.artist.country)} · ${escapeHtml(match.artist.style)} · ${escapeHtml(match.artist.dna.primaryAura)}</p>
          <div class="match-reasons">
            ${match.reasons.map(r => `<span class="dna-pill">${escapeHtml(r)}</span>`).join("")}
          </div>
          <div class="match-actions">
            <button class="mini-btn primary" onclick="setSpotlight('${match.artist.id}')">Spotlight</button>
            <button class="mini-btn" onclick="openDNA('${match.artist.id}')">DNA</button>
          </div>
        </div>`).join("");
    }

    function setMatchArtist(id) {
      const artist = artists.find(a => a.id === id);
      if (!artist) return;
      selectedMatchArtist = artist;
      renderVoiceMatches(artist);
      document.getElementById("voiceMatchSection").scrollIntoView({ behavior: "smooth" });
    }

    const dnaModal = document.getElementById("dnaModal");
    const canvas = document.getElementById("dnaCanvas");
    const ctx = canvas.getContext("2d");
    let animationFrameId = null;

    function openDNA(id) {
      const artist = artists.find(a => a.id === id);
      if (!artist) return;
      currentDNAArtist = artist;
      document.getElementById("modalTitle").textContent = `${artist.name} • Vocal DNA`;
      document.getElementById("modalPhoto").src = artist.image;
      document.getElementById("modalBio").textContent = artist.bio;
      document.getElementById("modalCountry").textContent = artist.country;
      document.getElementById("modalStyle").textContent = artist.style;
      document.getElementById("modalDNAID").textContent = artist.dna.dnaId;
      document.getElementById("dnaId").textContent = artist.dna.dnaId;
      document.getElementById("primaryAura").textContent = artist.dna.primaryAura;
      document.getElementById("voiceEnergy").textContent = artist.dna.voiceEnergy;
      document.getElementById("globalMatch").textContent = artist.dna.globalMatch;
      document.getElementById("auraSignature").textContent = artist.dna.auraSignature;
      document.getElementById("emotionalCore").textContent = artist.dna.emotionalCore;
      document.getElementById("voicePattern").textContent = artist.dna.voicePattern;
      document.getElementById("metricPower").textContent = artist.dna.power;
      document.getElementById("metricWarmth").textContent = artist.dna.warmth;
      document.getElementById("metricClarity").textContent = artist.dna.clarity;
      document.getElementById("metricRhythm").textContent = artist.dna.rhythm;
      document.getElementById("metricEmotion").textContent = artist.dna.emotion;
      const modalAudio = document.getElementById("modalAudio");
      if (artist.audio) { modalAudio.src = artist.audio; modalAudio.style.display = "block"; }
      else { modalAudio.removeAttribute("src"); modalAudio.style.display = "none"; }
      dnaModal.classList.add("show");
      startDNARender();
    }
    function closeDNA() { dnaModal.classList.remove("show"); if (animationFrameId) cancelAnimationFrame(animationFrameId); }
    dnaModal.addEventListener("click", function(e) { if (e.target === dnaModal) closeDNA(); });

    function drawBackground(w, h, t, dna) {
      const grad = ctx.createRadialGradient(w / 2, h / 2, 30, w / 2, h / 2, h / 1.2);
      grad.addColorStop(0, `hsla(${dna.hueA}, 80%, 58%, 0.16)`);
      grad.addColorStop(0.5, `hsla(${dna.hueB}, 80%, 50%, 0.08)`);
      grad.addColorStop(1, `rgba(2,6,23,0.96)`);
      ctx.fillStyle = grad; ctx.fillRect(0, 0, w, h);
      for (let i = 0; i < 90; i++) {
        const x = (i * 137.5 + t * 0.008 * (i % 5 + 1)) % w;
        const y = (i * 89.1 + t * 0.006 * (i % 7 + 1)) % h;
        const r = (i % 3) + 0.7;
        ctx.beginPath(); ctx.fillStyle = `hsla(${dna.hueC}, 90%, 80%, ${0.08 + (i % 4) * 0.03})`; ctx.arc(x, y, r, 0, Math.PI * 2); ctx.fill();
      }
    }
    function drawAuraRings(w, h, t, dna) {
      const cx = w / 2, cy = h / 2, energyFactor = dna.rhythm / 100;
      for (let layer = 0; layer < 5; layer++) {
        ctx.beginPath(); const baseRadius = 85 + layer * 28, points = 220;
        for (let i = 0; i <= points; i++) {
          const angle = (Math.PI * 2 * i) / points;
          const waveA = Math.sin(angle * (3 + layer) + t * 0.0017 * (layer + 1));
          const waveB = Math.cos(angle * (5 + layer) - t * 0.0014 * (layer + 2));
          const pulse = 12 * energyFactor * Math.sin(angle * 8 + t * 0.0024);
          const radius = baseRadius + waveA * 14 + waveB * 10 + pulse;
          const x = cx + Math.cos(angle) * radius, y = cy + Math.sin(angle) * radius;
          if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        }
        const hue = [dna.hueA, dna.hueB, dna.hueC, dna.hueA + 30, dna.hueB + 20][layer] % 360;
        ctx.strokeStyle = `hsla(${hue}, 90%, ${58 + layer * 4}%, ${0.18 + layer * 0.08})`;
        ctx.lineWidth = 2 + layer * 0.6; ctx.shadowBlur = 18 + layer * 5; ctx.shadowColor = `hsla(${hue}, 90%, 60%, 0.34)`; ctx.stroke();
      }
      ctx.shadowBlur = 0;
    }
    function drawDNAHelix(w, h, t, dna) {
      const cx = w / 2, cy = h / 2, helixHeight = 270, amplitude = 120 + (dna.power / 100) * 45;
      const top = cy - helixHeight / 2, bottom = cy + helixHeight / 2; ctx.lineWidth = 2;
      for (let strand = 0; strand < 2; strand++) {
        ctx.beginPath();
        for (let i = 0; i <= 140; i++) {
          const p = i / 140, y = top + p * (bottom - top), phase = p * Math.PI * 8 + t * 0.002 + strand * Math.PI, x = cx + Math.sin(phase) * amplitude * 0.55;
          if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        }
        const hue = strand === 0 ? dna.hueA : dna.hueB;
        ctx.strokeStyle = `hsla(${hue}, 90%, 64%, 0.8)`; ctx.shadowBlur = 16; ctx.shadowColor = `hsla(${hue}, 90%, 60%, 0.45)`; ctx.stroke();
      }
      for (let i = 0; i <= 24; i++) {
        const p = i / 24, y = top + p * (bottom - top), phase = p * Math.PI * 8 + t * 0.002;
        const x1 = cx + Math.sin(phase) * amplitude * 0.55, x2 = cx + Math.sin(phase + Math.PI) * amplitude * 0.55;
        ctx.beginPath(); ctx.moveTo(x1, y); ctx.lineTo(x2, y); ctx.strokeStyle = `hsla(${dna.hueC}, 95%, 70%, ${0.35 + 0.3 * Math.sin(t * 0.002 + i)})`; ctx.lineWidth = 1.6; ctx.stroke();
      }
      ctx.shadowBlur = 0;
    }
    function drawCoreOrb(w, h, t, dna) {
      const cx = w / 2, cy = h / 2, pulse = 1 + Math.sin(t * 0.004) * 0.05 + (dna.emotion / 100) * 0.12, r = 46 * pulse;
      const grad = ctx.createRadialGradient(cx, cy, 8, cx, cy, r * 2.1);
      grad.addColorStop(0, `hsla(${dna.hueC}, 100%, 88%, 0.95)`);
      grad.addColorStop(0.35, `hsla(${dna.hueA}, 100%, 68%, 0.75)`);
      grad.addColorStop(0.7, `hsla(${dna.hueB}, 100%, 58%, 0.28)`);
      grad.addColorStop(1, `hsla(${dna.hueB}, 100%, 45%, 0)`);
      ctx.beginPath(); ctx.fillStyle = grad; ctx.arc(cx, cy, r * 2.1, 0, Math.PI * 2); ctx.fill();
      ctx.beginPath(); ctx.fillStyle = `hsla(${dna.hueA}, 95%, 78%, 0.95)`; ctx.arc(cx, cy, r, 0, Math.PI * 2); ctx.fill();
    }
    function drawPulseDots(w, h, t, dna) {
      const cx = w / 2, cy = h / 2;
      for (let i = 0; i < 24; i++) {
        const angle = (Math.PI * 2 * i) / 24 + t * 0.00055;
        const dist = 165 + Math.sin(t * 0.002 + i) * 16 + (dna.clarity / 100) * 30;
        const x = cx + Math.cos(angle) * dist, y = cy + Math.sin(angle) * dist, r = 3 + ((i % 4) * 1.1);
        ctx.beginPath(); ctx.fillStyle = `hsla(${(dna.hueB + i * 7) % 360}, 95%, 72%, 0.88)`; ctx.shadowBlur = 14; ctx.shadowColor = `hsla(${(dna.hueB + i * 7) % 360}, 95%, 65%, 0.45)`; ctx.arc(x, y, r, 0, Math.PI * 2); ctx.fill();
      }
      ctx.shadowBlur = 0;
    }
    function drawBars(w, h, t, dna) {
      const bars = 52, barWidth = w / bars, bottom = h - 28;
      for (let i = 0; i < bars; i++) {
        const wave = (Math.sin(t * 0.003 + i * 0.35) + 1) / 2;
        const value = ((dna.rhythm + dna.power) / 200) * wave;
        const barHeight = 8 + value * 90, hue = (dna.hueA + i * 2.2) % 360;
        ctx.fillStyle = `hsla(${hue}, 90%, 62%, 0.72)`; ctx.fillRect(i * barWidth + 2, bottom - barHeight, barWidth - 4, barHeight);
      }
    }
    function renderDNAFrame(t = 0) {
      if (!currentDNAArtist) return;
      const dna = currentDNAArtist.dna, w = canvas.width, h = canvas.height;
      ctx.clearRect(0, 0, w, h);
      drawBackground(w, h, t, dna); drawAuraRings(w, h, t, dna); drawDNAHelix(w, h, t, dna); drawCoreOrb(w, h, t, dna); drawPulseDots(w, h, t, dna); drawBars(w, h, t, dna);
      animationFrameId = requestAnimationFrame(renderDNAFrame);
    }
    function startDNARender() { if (animationFrameId) cancelAnimationFrame(animationFrameId); renderDNAFrame(); }

    renderArtists();
  </script>
</body>
