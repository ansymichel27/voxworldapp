            <div class="metric"><strong id="metricPower">72</strong><span>Power</span></div>
            <div class="metric"><strong id="metricWarmth">81</strong><span>Warmth</span></div>
            <div class="metric"><strong id="metricClarity">76</strong><span>Clarity</span></div>
            <div class="metric"><strong id="metricRhythm">85</strong><span>Rhythm</span></div>
            <div class="metric"><strong id="metricEmotion">88</strong><span>Emotion</span></div>
          </div>
        </div>
