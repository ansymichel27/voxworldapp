<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VoxWorld | Global Artist Galaxy + Vocal DNA + World Map + Voice Match</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{
      --bg:#020617;
      --bg2:#081120;
      --panel:rgba(15,23,42,.78);
      --card:rgba(15,23,42,.88);
      --line:rgba(255,255,255,.08);
      --text:#fff;
      --muted:#cbd5e1;
      --blue:#38bdf8;
      --purple:#8b5cf6;
      --pink:#ec4899;
      --green:#22c55e;
      --gold:#facc15;
      --red:#ef4444;
      --orange:#f97316;
    }
    body{
      font-family:Arial,sans-serif;
      color:var(--text);
      min-height:100vh;
      background:
        radial-gradient(circle at top left, rgba(56,189,248,.16), transparent 24%),
        radial-gradient(circle at top right, rgba(236,72,153,.15), transparent 24%),
        linear-gradient(180deg,#020617 0%,#081120 46%,#020617 100%);
    }
    .hero{position:relative;padding:88px 20px 54px;overflow:hidden}
    .hero::before{
      content:"";position:absolute;inset:0;
      background:linear-gradient(to bottom, rgba(2,6,23,.18), rgba(2,6,23,.9)),
      url("https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?q=80&w=1600&auto=format&fit=crop") center/cover no-repeat;
      opacity:.22;
    }
    .hero-inner{position:relative;z-index:1;max-width:1380px;margin:auto;display:grid;grid-template-columns:1.1fr .9fr;gap:28px;align-items:center}
    .hero-copy h1{font-size:62px;line-height:1.01;letter-spacing:-1px;margin-bottom:16px}
    .hero-copy h1 span{background:linear-gradient(90deg,var(--blue),var(--purple),var(--pink),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;color:transparent}
    .hero-copy p{color:var(--muted);font-size:19px;line-height:1.7;max-width:770px;margin-bottom:26px}
    .hero-actions{display:flex;flex-wrap:wrap;gap:14px;margin-bottom:24px}
    .btn{border:none;border-radius:15px;padding:14px 22px;font-size:15px;font-weight:bold;cursor:pointer;transition:.25s ease;color:white}
    .btn-primary{background:linear-gradient(90deg,var(--blue),var(--purple));box-shadow:0 14px 30px rgba(56,189,248,.2)}
    .btn-secondary{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1)}
    .btn-orange{background:linear-gradient(90deg,var(--orange),var(--pink))}
    .btn:hover{transform:translateY(-2px);opacity:.96}
    .hero-stats{display:flex;flex-wrap:wrap;gap:14px}
    .stat{min-width:150px;padding:16px 18px;border-radius:16px;background:rgba(255,255,255,.05);border:1px solid var(--line);backdrop-filter:blur(12px)}
    .stat strong{display:block;font-size:24px;margin-bottom:6px}
    .stat span{font-size:14px;color:var(--muted)}
    .spotlight-panel{background:rgba(10,15,28,.74);border:1px solid var(--line);border-radius:28px;padding:20px;backdrop-filter:blur(18px);box-shadow:0 20px 50px rgba(0,0,0,.34)}
    .panel-title{font-size:18px;color:var(--blue);font-weight:bold;margin-bottom:14px}
    .spotlight-card{position:relative;overflow:hidden;border-radius:24px;min-height:390px;background:#111827}
    .spotlight-card img{width:100%;height:390px;object-fit:cover;display:block}
    .spotlight-overlay{position:absolute;inset:0;background:linear-gradient(to top, rgba(2,6,23,.96), rgba(2,6,23,.18));display:flex;flex-direction:column;justify-content:flex-end;padding:22px}
    .world-badge{display:inline-block;width:fit-content;padding:7px 12px;border-radius:999px;background:linear-gradient(90deg,var(--gold),#f59e0b);color:#111827;font-size:12px;font-weight:bold;margin-bottom:10px}
    .spotlight-overlay h3{font-size:30px;margin-bottom:6px}
    .spotlight-overlay p{color:var(--muted);line-height:1.6;font-size:14px;margin-bottom:14px}
    .spotlight-tags,.tag-row{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:14px}
    .tag{padding:8px 12px;border-radius:999px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.08);font-size:12px;color:#dbeafe}
    .marquee-wrap{overflow:hidden;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(255,255,255,.03);margin:26px 0 34px}
    .marquee{display:flex;width:max-content;gap:18px;padding:16px 0;animation:scrollMove 26s linear infinite}
    .marquee span{padding:10px 18px;border-radius:999px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.06);color:#dbeafe;font-size:14px}
    @keyframes scrollMove{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .main-wrap{max-width:1380px;margin:auto;padding:0 20px 70px}
    .layout{display:grid;grid-template-columns:400px 1fr;gap:26px;align-items:start}
    .form-box{position:sticky;top:20px;background:rgba(255,255,255,.05);border:1px solid var(--line);border-radius:28px;padding:22px;backdrop-filter:blur(16px);box-shadow:0 16px 42px rgba(0,0,0,.25)}
    .form-box h2{font-size:30px;margin-bottom:10px}.form-box p{color:var(--muted);line-height:1.6;font-size:14px;margin-bottom:18px}
    .form-group{margin-bottom:14px}.form-group label{display:block;font-size:13px;font-weight:bold;margin-bottom:7px;color:#e5e7eb}
    .form-group input,.form-group select,.form-group textarea{width:100%;border-radius:14px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.06);color:white;padding:13px 14px;font-size:14px;outline:none}
    .form-group textarea{min-height:96px;resize:vertical}
    .small-note{margin-top:12px;color:#93c5fd;font-size:13px;line-height:1.6}
    .gallery-box{min-width:0}
    .filters{background:rgba(255,255,255,.04);border:1px solid var(--line);border-radius:24px;padding:18px;display:grid;grid-template-columns:1.25fr 1fr 1fr;gap:12px;margin-bottom:20px;backdrop-filter:blur(10px)}
    .filters input,.filters select{width:100%;padding:14px 15px;border-radius:14px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.06);color:white;outline:none;font-size:14px}
    .section-head{display:flex;justify-content:space-between;align-items:end;gap:14px;flex-wrap:wrap;margin-bottom:18px}
    .section-head h2{font-size:34px;margin-bottom:6px}.section-head p{color:var(--muted);line-height:1.6;max-width:850px}
    .artist-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:22px}
    .artist-card{position:relative;background:var(--card);border:1px solid rgba(255,255,255,.08);border-radius:24px;overflow:hidden;box-shadow:0 18px 40px rgba(0,0,0,.28);transition:.3s ease;backdrop-filter:blur(12px)}
    .artist-card:hover{transform:translateY(-8px) scale(1.01);border-color:rgba(56,189,248,.34);box-shadow:0 22px 48px rgba(56,189,248,.16)}
    .artist-media{position:relative;height:290px;overflow:hidden;background:#111827}.artist-media img{width:100%;height:100%;object-fit:cover;display:block}
    .artist-chip{position:absolute;top:14px;left:14px;background:rgba(2,6,23,.78);border:1px solid rgba(255,255,255,.12);color:white;padding:7px 11px;border-radius:999px;font-size:12px;backdrop-filter:blur(8px)}
    .dna-chip{position:absolute;right:14px;top:14px;background:linear-gradient(90deg,var(--pink),var(--purple));color:white;font-size:12px;font-weight:bold;padding:8px 11px;border-radius:999px;box-shadow:0 10px 24px rgba(236,72,153,.22)}
    .artist-content{padding:20px}.artist-top{display:flex;justify-content:space-between;gap:10px;align-items:start;margin-bottom:10px}
    .artist-name{font-size:24px;margin-bottom:5px}.artist-meta{font-size:14px;color:var(--muted);line-height:1.5}
    .rank-badge{white-space:nowrap;padding:8px 10px;border-radius:12px;background:linear-gradient(90deg,#f59e0b,#facc15);color:#111827;font-size:12px;font-weight:bold}
    .artist-bio{color:#e5e7eb;font-size:14px;line-height:1.65;margin:14px 0 15px;min-height:70px}
    .dna-row{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px}.dna-pill{padding:8px 10px;border-radius:999px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.06);color:#dbeafe;font-size:12px}
    .artist-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:15px}
    .mini-stat{border-radius:14px;padding:12px;text-align:center;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.06)}
    .mini-stat strong{display:block;font-size:16px;margin-bottom:4px}.mini-stat span{font-size:12px;color:var(--muted)}
    audio{width:100%;margin-bottom:15px;border-radius:14px}
    .artist-actions{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
    .artist-actions button{padding:11px 8px;border:none;border-radius:12px;font-size:13px;font-weight:bold;cursor:pointer;color:white;transition:.25s ease}
    .like-btn{background:var(--red)}.follow-btn{background:var(--green)}.collab-btn{background:var(--blue)}.dna-btn{background:var(--purple)}
    .artist-actions button:hover{transform:scale(1.03);opacity:.93}
    .empty-state{display:none;border:1px dashed rgba(255,255,255,.12);border-radius:22px;padding:28px;text-align:center;color:var(--muted);background:rgba(255,255,255,.03)}
    .map-panel,.match-panel{margin-top:26px;background:rgba(255,255,255,.04);border:1px solid var(--line);border-radius:28px;padding:20px;backdrop-filter:blur(14px)}
    .map-header,.match-header{display:flex;justify-content:space-between;gap:12px;align-items:end;flex-wrap:wrap;margin-bottom:16px}
    .map-header h3,.match-header h3{font-size:30px}.map-header p,.match-header p{color:var(--muted);max-width:820px;line-height:1.6}
    .world-map-wrap{position:relative;border-radius:24px;overflow:hidden;background:linear-gradient(180deg,rgba(255,255,255,.03),rgba(255,255,255,.015));border:1px solid rgba(255,255,255,.08);padding:12px}
    svg.world-map{width:100%;height:auto;display:block}
    .map-svg-bg{fill:#0a1424;stroke:rgba(255,255,255,.06);stroke-width:1}
    .continent{fill:rgba(56,189,248,.08);stroke:rgba(148,163,184,.18);stroke-width:1.2}
    .country-dot{cursor:pointer;transition:.2s ease}
    .country-dot:hover{transform:scale(1.12)}
    .map-legend{display:flex;flex-wrap:wrap;gap:10px;margin-top:14px}.legend-pill{padding:8px 12px;border-radius:999px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.06);font-size:12px;color:#dbeafe}
    .country-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;margin-top:18px}
    .country-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:16px}
    .country-card h4{font-size:20px;margin-bottom:6px}.country-card p{color:var(--muted);font-size:14px;line-height:1.6;margin-bottom:10px}
    .country-card strong{font-size:22px}
    .match-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    .match-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:22px;padding:18px;position:relative;overflow:hidden}
    .match-card::before{content:"";position:absolute;inset:auto -20% -40% auto;width:180px;height:180px;background:radial-gradient(circle,rgba(56,189,248,.16),transparent 65%);pointer-events:none}
    .match-score{display:inline-block;padding:7px 10px;border-radius:999px;background:linear-gradient(90deg,var(--blue),var(--purple));font-size:12px;font-weight:bold;margin-bottom:10px}
    .match-card h4{font-size:23px;margin-bottom:6px}.match-card p{color:var(--muted);font-size:14px;line-height:1.6;margin-bottom:12px}
    .match-reasons{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px}
    .match-actions{display:flex;gap:10px;flex-wrap:wrap}.mini-btn{border:none;border-radius:12px;padding:10px 14px;font-weight:bold;cursor:pointer;color:white;background:rgba(255,255,255,.08)}.mini-btn.primary{background:linear-gradient(90deg,var(--green),var(--blue))}
    .cta{margin-top:35px;padding:34px 24px;text-align:center;border-radius:28px;background:linear-gradient(135deg,rgba(56,189,248,.14),rgba(139,92,246,.16));border:1px solid rgba(255,255,255,.08)}
    .cta h3{font-size:34px;margin-bottom:12px}.cta p{color:var(--muted);line-height:1.7;max-width:850px;margin:0 auto 20px}
    .footer-note{text-align:center;padding:26px 20px 40px;color:#94a3b8;font-size:14px}
    .modal{position:fixed;inset:0;background:rgba(2,6,23,.78);backdrop-filter:blur(10px);display:none;align-items:center;justify-content:center;padding:20px;z-index:999}
    .modal.show{display:flex}.modal-card{width:min(1100px,100%);background:rgba(8,17,32,.96);border:1px solid rgba(255,255,255,.08);border-radius:28px;overflow:hidden;box-shadow:0 30px 70px rgba(0,0,0,.4)}
    .modal-top{display:flex;justify-content:space-between;align-items:center;padding:18px 20px;border-bottom:1px solid rgba(255,255,255,.07)}.modal-top h3{font-size:24px}
    .close-btn{border:none;background:rgba(255,255,255,.08);color:white;border-radius:12px;padding:10px 14px;cursor:pointer;font-weight:bold}
    .modal-body{display:grid;grid-template-columns:340px 1fr;gap:0}.modal-side{padding:22px;border-right:1px solid rgba(255,255,255,.07);background:rgba(255,255,255,.03)}
    .modal-photo{width:100%;height:320px;border-radius:22px;overflow:hidden;margin-bottom:16px;background:#111827}.modal-photo img{width:100%;height:100%;object-fit:cover;display:block}
    .modal-side p{color:var(--muted);font-size:14px;line-height:1.7;margin-bottom:14px}.modal-main{padding:20px}
    .dna-top-cards{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px}.dna-stat-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:14px}
    .dna-stat-card span{display:block;color:var(--muted);font-size:12px;margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em}.dna-stat-card strong{font-size:20px}
    .dna-canvas-wrap{position:relative;min-height:480px;overflow:hidden;border-radius:26px;background:radial-gradient(circle at center, rgba(56,189,248,.10), transparent 25%),linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015));border:1px solid rgba(255,255,255,.08);margin-bottom:16px}
    #dnaCanvas{width:100%;height:480px;display:block}
    .canvas-overlay{position:absolute;top:18px;left:18px;right:18px;display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;pointer-events:none}
    .glass-badge{background:rgba(2,6,23,.58);border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:11px 13px;backdrop-filter:blur(12px);min-width:180px}
    .glass-badge .label{display:block;font-size:11px;color:#cbd5e1;margin-bottom:6px;letter-spacing:.08em;text-transform:uppercase}.glass-badge .value{display:block;font-size:17px;font-weight:bold}
    .metrics{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}.metric{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:14px;text-align:center}
    .metric strong{display:block;font-size:21px;margin-bottom:6px}.metric span{color:var(--muted);font-size:12px}
    @media (max-width:1140px){.hero-inner{grid-template-columns:1fr}.hero-copy h1{font-size:50px}.layout{grid-template-columns:1fr}.form-box{position:relative;top:auto}.modal-body{grid-template-columns:1fr}.modal-side{border-right:none;border-bottom:1px solid rgba(255,255,255,.07)}.match-grid{grid-template-columns:1fr}}
    @media (max-width:760px){.hero-copy h1{font-size:40px}.filters{grid-template-columns:1fr}.artist-actions{grid-template-columns:repeat(2,1fr)}.dna-top-cards{grid-template-columns:repeat(2,1fr)}.metrics{grid-template-columns:repeat(2,1fr)}.country-cards{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-copy">
        <h1>The <span>World’s Artist Galaxy</span> with Vocal DNA</h1>
        <p>
          VoxWorld becomes more than a feed when every artist has a living identity, a world presence,
          and instant AI-style collaboration proposals. This single file includes the gallery, Vocal DNA,
          a world map, and Voice Match in one experience.
        </p>
        <div class="hero-actions">
          <button class="btn btn-primary" onclick="scrollToSignup()">Create Artist Profile</button>
          <button class="btn btn-secondary" onclick="scrollToGallery()">Explore Gallery</button>
          <button class="btn btn-orange" onclick="scrollToMap()">Open World Map</button>
        </div>
        <div class="hero-stats">
          <div class="stat"><strong id="countriesStat">190+</strong><span>Countries Reach</span></div>
          <div class="stat"><strong>24/7</strong><span>Artist Discovery</span></div>
          <div class="stat"><strong id="artistsStat">0</strong><span>Artists Visible</span></div>
          <div class="stat"><strong id="matchesStat">0</strong><span>Voice Matches</span></div>
        </div>
      </div>
      <div class="spotlight-panel">
        <div class="panel-title">Featured Global Spotlight</div>
        <div class="spotlight-card">
          <img id="spotlightImage" src="https://images.unsplash.com/photo-1516280440614-37939bbacd81?q=80&w=1400&auto=format&fit=crop" alt="Featured artist">
          <div class="spotlight-overlay">
            <span class="world-badge">WORLD FEATURED ARTIST</span>
            <h3 id="spotlightName">Ansy Michel</h3>
            <p id="spotlightDesc">Future Kompa, Haitian excellence, global voice innovation, and premium digital identity.</p>
            <div class="spotlight-tags">
              <span class="tag" id="spotlightDNA">VX-0000-0000</span>
              <span class="tag" id="spotlightAura">Celestial Blue</span>
              <span class="tag" id="spotlightEnergy">Balanced</span>
            </div>
            <div class="hero-actions" style="margin-bottom:0">
              <button class="btn btn-primary" onclick="openSpotlightDNA()">Open Vocal DNA</button>
              <button class="btn btn-secondary" onclick="openSpotlightMatch()">Open Voice Match</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="marquee-wrap">
    <div class="marquee">
      <span>Vocal DNA</span><span>Living Voice Identity</span><span>World Map Discovery</span><span>Voice Match AI</span>
      <span>Kompa Voices</span><span>Afrobeats Creators</span><span>Global Gospel</span><span>Rap Identity</span>
      <span>Pop Stars</span><span>Creator Matchmaking</span><span>Artist Collaborations</span>
      <span>Vocal DNA</span><span>Living Voice Identity</span><span>World Map Discovery</span><span>Voice Match AI</span>
      <span>Kompa Voices</span><span>Afrobeats Creators</span><span>Global Gospel</span><span>Rap Identity</span>
      <span>Pop Stars</span><span>Creator Matchmaking</span><span>Artist Collaborations</span>
    </div>
  </div>

  <main class="main-wrap">
    <div class="layout">
      <aside class="form-box" id="signupBox">
        <h2>Create Artist + Vocal DNA</h2>
        <p>
          Publish an artist with photo, audio, Vocal DNA identity, world visibility, and instant Voice Match suggestions.
        </p>
        <form id="artistForm">
          <div class="form-group">
            <label for="artistName">Artist Name / Stage Name</label>
            <input type="text" id="artistName" required placeholder="Ex: Ansy Michel">
          </div>
          <div class="form-group">
            <label for="artistCountry">Country</label>
            <input type="text" id="artistCountry" required placeholder="Ex: Haiti / USA">
          </div>
          <div class="form-group">
            <label for="artistStyle">Voice Style</label>
            <select id="artistStyle" required>
              <option value="">Select a style</option>
              <option value="Kompa">Kompa</option>
              <option value="Afrobeat">Afrobeat</option>
              <option value="Soul">Soul</option>
              <option value="Rap">Rap</option>
              <option value="Pop">Pop</option>
              <option value="Gospel">Gospel</option>
              <option value="Fusion">Fusion</option>
            </select>
          </div>
          <div class="form-group">
            <label for="artistBio">Artist Bio / Voice Identity</label>
            <textarea id="artistBio" required placeholder="Tell the world what makes this voice unique..."></textarea>
          </div>
          <div class="form-group">
            <label for="artistImage">Profile Picture</label>
            <input type="file" id="artistImage" accept="image/*" required>
          </div>
          <div class="form-group">
            <label for="artistAudio">Voice Sample</label>
            <input type="file" id="artistAudio" accept="audio/*">
          </div>
          <button class="btn btn-primary" type="submit" style="width:100%">Publish to Gallery</button>
          <div class="small-note">
            Demo version: everything is saved in this browser with localStorage. Later you can connect it to Supabase or Firebase.
          </div>
        </form>
      </aside>

      <section class="gallery-box" id="galleryBox">
        <div class="filters">
          <input type="text" id="searchInput" placeholder="Search artist, country, style, DNA..." onkeyup="filterArtists()">
          <select id="styleFilter" onchange="filterArtists()">
            <option value="all">All Styles</option>
            <option value="Kompa">Kompa</option>
            <option value="Afrobeat">Afrobeat</option>
            <option value="Soul">Soul</option>
            <option value="Rap">Rap</option>
            <option value="Pop">Pop</option>
            <option value="Gospel">Gospel</option>
            <option value="Fusion">Fusion</option>
          </select>
          <select id="countryFilter" onchange="filterArtists()">
            <option value="all">All Countries</option>
            <option value="Haiti">Haiti</option>
            <option value="USA">USA</option>
            <option value="France">France</option>
            <option value="Nigeria">Nigeria</option>
            <option value="Canada">Canada</option>
          </select>
        </div>
        <div class="section-head">
          <div>
            <h2>Explore the World’s Artists</h2>
            <p>Every card shows photo, voice, Vocal DNA, aura, energy, and direct actions for spotlight and Voice Match.</p>
          </div>
        </div>
        <div class="artist-grid" id="artistGrid"></div>
        <div class="empty-state" id="emptyState">No artist matches your search right now.</div>

        <section class="map-panel" id="worldMapSection">
          <div class="map-header">
            <div>
