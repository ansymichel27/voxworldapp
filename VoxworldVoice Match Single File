              <div class="glass-badge"><span class="label">Aura Signature</span><span class="value" id="auraSignature">Ocean Pulse</span></div>
              <div class="glass-badge"><span class="label">Emotional Core</span><span class="value" id="emotionalCore">Warm / Expansive</span></div>
              <div class="glass-badge"><span class="label">Voice Pattern</span><span class="value" id="voicePattern">Radiant Spiral</span></div>
