        </div>
        <div class="modal-main">
          <div class="dna-top-cards">
            <div class="dna-stat-card"><span>Vocal DNA ID</span><strong id="dnaId">VX-0000-0000</strong></div>
            <div class="dna-stat-card"><span>Primary Aura</span><strong id="primaryAura">Celestial Blue</strong></div>
            <div class="dna-stat-card"><span>Voice Energy</span><strong id="voiceEnergy">Balanced</strong></div>
            <div class="dna-stat-card"><span>Global Match</span><strong id="globalMatch">Creative Pulse</strong></div>
